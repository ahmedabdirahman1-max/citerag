# Copy to .env to enable LLM-generated grounded answers. Optional — the app works without it.
ANTHROPIC_API_KEY=
# Model used only to phrase an answer from already-retrieved chunks (it cannot reach
# outside the retrieved context, and is instructed to refuse if the answer isn't there).
ANSWER_MODEL=claude-haiku-4-5-20251001
# Retrieval / refusal tuning (sensible defaults; override only if you know why).
TOP_K=4
REFUSAL_THRESHOLD=0.06
